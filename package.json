{
  "name": "flowise",
  "version": "1.0.0",
  "description": "Drag & drop UI to build your customized LLM flow",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "turbo run clean",
    "nuke": "turbo run nuke",
    "test": "turbo run test",
    "dev:backend": "turbo run dev --filter=flowise-server",
    "dev:ui": "turbo run dev --filter=flowise-ui",
    "dev:verbose": "turbo run dev --parallel --verbosity=2",
    "dev:fresh": "turbo run clean && turbo run dev --parallel --force",
    "lint:fix": "turbo run lint -- --fix"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "eslint": "^8.38.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "prettier": "^2.8.7",
    "turbo": "^1.9.3",
    "typescript": "^5.0.4"
  },
  "engines": {
    "node": ">=18.15.0",
    "npm": ">=9.6.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FlowiseAI/Flowise.git"
  },
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/FlowiseAI/Flowise/issues"
  },
  "homepage": "https://github.com/FlowiseAI/Flowise#readme",
  "keywords": [
    "langchain",
    "openai",
    "llm",
    "chatbot",
    "flowise",
    "rag",
    "agents",
    "personal-fork"
  ],
  "_comment": "Personal fork for learning LLM orchestration patterns. Upstream: FlowiseAI/Flowise",
  "_notes": "dev:verbose is handy when debugging turbo task ordering or cache misses. dev:fresh clears turbo cache before starting — useful after dependency changes. lint:fix runs eslint with auto-fix across all packages."
}
